# Application — URL publique utilisée pour les redirects Auth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — public (utiliser https:// pour les projets cloud *.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only
SUPABASE_SERVICE_ROLE_KEY=
# HMAC dédié aux tokens d'autorisation future (jamais NEXT_PUBLIC_,
# jamais recyclé depuis SUPABASE_SERVICE_ROLE_KEY). ≥ 32 caractères.
SIDIAN_PAYMENT_AUTHORIZATION_TOKEN_SECRET=
# Référence du projet (sous-domaine avant .supabase.co/.supabase.in).
# Obligatoire et vérifiée au build sur Vercel Preview et Production.
SIDIAN_SUPABASE_PROJECT_REF=
# JWT minimal signé par le projet ciblé, role=sidian_environment_attestor,
# claims sidian_environment + sidian_project_ref. Obligatoire sur Vercel.
SUPABASE_ENVIRONMENT_ATTESTATION_JWT=
# JWT pré-généré portant role=stripe_customer_binding_writer et
# sidian_environment=local|staging|production. Requis uniquement si Stripe=true.
SUPABASE_STRIPE_BINDING_WRITER_JWT=

# local | staging | production. Obligatoire sur Vercel, même si Stripe=false.
SIDIAN_ENVIRONMENT=local

# Stripe — readiness explicite. Un build sans paiements utilise false.
NEXT_PUBLIC_STRIPE_PAYMENTS_ENABLED=false
STRIPE_MODE=test
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_CONNECT_WEBHOOK_SECRET=

# AI — future phase
OPENAI_API_KEY=

# Email — future phase
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=
