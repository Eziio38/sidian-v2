# Application — URL publique utilisée pour les redirects Auth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — public (utiliser https:// pour les projets cloud *.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only
SUPABASE_SERVICE_ROLE_KEY=
# JWT pré-généré portant role=stripe_customer_binding_writer et
# sidian_environment=local|staging|production. Requis uniquement si Stripe=true.
SUPABASE_STRIPE_BINDING_WRITER_JWT=

# Stripe — readiness explicite. Un build sans paiements utilise false.
NEXT_PUBLIC_STRIPE_PAYMENTS_ENABLED=false
# local | staging | production (requis lorsque Stripe est activé)
SIDIAN_ENVIRONMENT=local
STRIPE_MODE=test
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_CONNECT_WEBHOOK_SECRET=

# AI — future phase
OPENAI_API_KEY=

# Email — future phase
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=
